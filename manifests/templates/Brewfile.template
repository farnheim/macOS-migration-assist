# Brewfile — VERIFIED projection of selected items (install_method ∈ tap|formula|cask|mas)
# Source of truth: homebrew.json + applications.json. Regenerated by /verify after selection changes.
# This is NOT a blind `brew bundle dump` — only items with "selected": true belong here.
# Install on the target with:  brew bundle --file=manifests/Brewfile
# Order: taps → brews → casks → mas.

tap "<owner>/<repo>"

brew "<formula-name>"

cask "<cask-slug>"

mas "<App Name>", id: <numeric-id>
